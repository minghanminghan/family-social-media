# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal secret shared between Next.js routes and server actions
EMBED_SECRET=change-me-random-string

# Modal — get these after `modal deploy modal/embed.py`
MODAL_EMBED_URL=https://your-modal-app--embed.modal.run
MODAL_EMBED_QUERY_URL=https://your-modal-app--embed-query.modal.run
MODAL_TOKEN=your-modal-token
